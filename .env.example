# ---- Kelime Tahmin — ortam değişkenleri örneği ----
# Coolify'da bu değerleri "Environment Variables" bölümüne gir.
# Gerçek değerleri ASLA git'e commit'leme; bu dosya yalnızca şablondur.

# Genel
APP_NAME=Kelime Tahmin
ENVIRONMENT=production
DEFAULT_LANG=tr
GAME_LANG=tr

# Veritabanı (Coolify'da güçlü bir şifre gir)
POSTGRES_USER=kelime
POSTGRES_PASSWORD=degistir-guclu-bir-sifre
POSTGRES_DB=kelimetahmin

# Güvenlik
JWT_SECRET=uzun-rastgele-bir-secret-uret

# Frontend -> Backend bağlantısı
# Tek domain + reverse proxy kullanıyorsan boş bırak (aynı origin /api).
# Ayrı domain/subdomain ise backend'in tam adresini yaz: https://api.kelimetahmin.com
NEXT_PUBLIC_API_BASE=
FRONTEND_ORIGIN=*

# Google OAuth (Faz 3'te aktif olacak — şimdilik boş kalabilir)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Portlar (Coolify genelde kendi yönetir; gerekirse değiştir)
BACKEND_PORT=8000
FRONTEND_PORT=3000
